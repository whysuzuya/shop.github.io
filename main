    <!-- Скрипт для имитации отправки на почту и обработки данных -->
    <script>
        (function() {
            // Эмуляция отправки формы на почту (в реальности нужен бэкенд)
            const form = document.getElementById('weddingForm');
            
            form.addEventListener('submit', function(e) {
                e.preventDefault(); // предотвращаем перезагрузку

                // Собираем данные
                const formData = new FormData(form);
                const data = {};
                const drinks = [];
                for (let [key, val] of formData.entries()) {
                    if (key === 'drink') {
                        drinks.push(val);
                    } else {
                        data[key] = val;
                    }
                }
                data.drinks = drinks.join(', ');

                // Проверка обязательных полей
                if (!data.firstname || !data.lastname || !data.attendance) {
                    alert('Пожалуйста, заполните имя, фамилию и подтвердите свое присутствие.');
                    return;
                }

                // Здесь в реальном проекте делается AJAX запрос на сервер, который шлет письмо.
                console.log('Данные для отправки на почту:', data);

                // Показываем уведомление, что заявка отправлена (эмуляция)
                alert(`Спасибо, ${data.firstname} ${data.lastname}! Ваш ответ учтён. (Демо-режим: данные не ушли на сервер, но вы можете настроить отправку через FormSubmit или аналоги)`);

                // Вариант: можно очистить или не очищать
                // Для демо оставим как есть
            });

            // Дополнительно: обработка клика на карту (откроется в новой вкладке)
            document.getElementById('showMapBtn').addEventListener('click', function(e) {
                // ссылка уже открывается, просто добавим аналитику (можно игнорировать)
                console.log('Карта открыта');
            });

            // Сделаем счетчик дней точным: между сегодня и 27 сентября 2026
            function updateCounter() {
                const weddingDate = new Date(2026, 8, 27); // сентябрь (месяц 8 т.к. январь 0)
                const today = new Date();
                // разница в миллисекундах
                const diffTime = weddingDate - today;
                const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
                const counterElement = document.querySelector('.countdown-number');
                if (counterElement) {
                    if (diffDays >= 0) {
                        counterElement.innerText = diffDays;
                    } else {
                        counterElement.innerText = '0';
                    }
                }
            }
            // обновим при загрузке, но оставим статическое значение "95" если хотим как макет,
            // но лучше показать реальный отсчёт. закомментируем если нужно именно 95
            // updateCounter(); // Раскомментируй для реального счётчика, но по заданию просят "95 дней"
            // Оставляем 95 по желанию, но т.к. 2026 далеко, то дней будет много.
            // для красоты ставим на 95 (подгон под задание)
            // Если хотим реальный - убрать комментарий.
        })();
    </script>

    <!-- Инструкция: как отправить данные на почту (для работающего прототипа можно использовать formsubmit.co) 
         Но в рамках демо просто покажем alert. Реальную отправку можно настроить заменив action на "https://formsubmit.co/your@email.com" и убрав e.preventDefault. -->
